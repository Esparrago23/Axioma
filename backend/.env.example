# Base de Datos
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=

# Seguridad JWT
SECRET_KEY=
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=

# Object storage (S3 compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=
AWS_ENDPOINT_URL=
AWS_PUBLIC_ENDPOINT_URL=

# Firebase Cloud Messaging
# Opcion 1: pegar el JSON del service account en una sola linea
FIREBASE_CREDENTIALS_JSON=

# Opcion 2: usar una ruta de archivo local o montada en Docker
# Recomendado con docker-compose: ./backend/secrets/firebase-service-account.json
FIREBASE_CREDENTIALS_FILE=/run/secrets/firebase-service-account.json

# Radio maximo para decidir que usuarios reciben alertas por cercania
NOTIFICATIONS_RADIUS_KM=5